@ThermalPrinterService_HostAddress = http://localhost:5133

POST {{ThermalPrinterService_HostAddress}}/connect
Content-Type: application/json

{
  "mode": "usb"
}

###

GET {{ThermalPrinterService_HostAddress}}/status
Accept: application/json

###

POST {{ThermalPrinterService_HostAddress}}/print/text
Content-Type: application/json

{
  "text": "Hello from thermal printer service"
}

###

POST {{ThermalPrinterService_HostAddress}}/print/image
Content-Type: multipart/form-data; boundary=boundary

--boundary
Content-Disposition: form-data; name="image"; filename="sample.png"
Content-Type: image/png

sample image content
--boundary--

###

GET {{ThermalPrinterService_HostAddress}}/logs
Accept: application/json

###

POST {{ThermalPrinterService_HostAddress}}/simulate-error
Content-Type: application/json

{
  "errorCode": "PAPER_OUT"
}

###

POST {{ThermalPrinterService_HostAddress}}/clear-error
Accept: application/json

###

POST {{ThermalPrinterService_HostAddress}}/reprint
Accept: application/json
